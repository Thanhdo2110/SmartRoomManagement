<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Nền Gradient mượt mà (Deep Velvet) -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="#1E1B4B"
                android:centerColor="#312E81"
                android:endColor="#4338CA"
                android:type="linear" />
        </shape>
    </item>

    <!-- Khối sáng Organic (Top Right) -->
    <item android:top="-100dp" android:right="-100dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:startColor="#33818CF8"
                android:endColor="#00000000" />
            <size android:width="500dp" android:height="500dp" />
        </shape>
    </item>

    <!-- Khối sáng Soft Glow (Bottom Left) -->
    <item android:bottom="-150dp" android:left="-80dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="500dp"
                android:startColor="#26C082FF"
                android:endColor="#00000000" />
            <size android:width="600dp" android:height="600dp" />
        </shape>
    </item>

    <!-- Lớp phủ tạo hạt mịn (Subtle Grain/Noise effect giả lập) -->
    <item>
        <shape>
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#22000000"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>