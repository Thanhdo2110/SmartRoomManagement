<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="Quản lý phòng"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

        <!-- Ô Tìm kiếm -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            app:hintEnabled="false"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            app:boxBackgroundColor="#F1F5F9"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_search_room"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tìm theo tên phòng..."
                android:paddingVertical="10dp"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Bộ lọc Trạng thái (Category Chips) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"
            android:baselineAligned="false">

            <!-- Tất cả -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_filter_all"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#6366F1"
                android:backgroundTint="#EEF2FF"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:id="@+id/text_all_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:text="Tất cả"
                    android:textColor="#6366F1"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Đã thuê -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_filter_occupied"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="3dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9"
                android:backgroundTint="#FFFFFF"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">
                    <TextView
                        android:id="@+id/label_occupied"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đã thuê"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/text_occupied_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="0"
                        android:textColor="#EF4444"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Trống -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_filter_vacant"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9"
                android:backgroundTint="#FFFFFF"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">
                    <TextView
                        android:id="@+id/label_vacant"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trống"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/text_vacant_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="0"
                        android:textColor="#10B981"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Trạng thái trống (Empty State) -->
    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:alpha="0.2"
            android:src="@drawable/ic_room_premium"
            app:tint="#64748B" />

        <TextView
            android:id="@+id/text_empty_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Không tìm thấy phòng"
            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:textColor="#64748B" />

        <TextView
            android:id="@+id/text_empty_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Thử đổi bộ lọc hoặc tìm tên phòng khác"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="#94A3B8"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_add_first_room"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Thêm phòng ngay"
            app:icon="@android:drawable/ic_input_add" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_rooms"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="12dp"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add_room"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:text="Thêm phòng"
        android:textColor="@android:color/white"
        app:backgroundTint="#6366F1"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="@android:color/white"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>