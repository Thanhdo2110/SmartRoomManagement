<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/text_payment_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quét mã để thanh toán"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/text_payment_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phòng 101 - Tháng 05/2024"
        android:textColor="#64748B"
        android:layout_marginBottom="16dp"/>

    <ProgressBar
        android:id="@+id/progress_qr"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginBottom="-40dp"
        android:elevation="2dp" />

    <ImageView
        android:id="@+id/image_qr"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:scaleType="fitCenter"
        android:layout_marginBottom="16dp"
        android:background="#F8FAFC"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/text_payment_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tổng tiền: 2.500.000đ"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#10B981"
        android:layout_marginBottom="20dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close_payment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đóng"
        style="@style/Widget.Material3.Button.TonalButton"/>

</LinearLayout>
